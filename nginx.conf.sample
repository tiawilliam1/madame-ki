# Nginx sample server configuration for language routing
server {
  listen 80;
  server_name example.com;

  root /var/www/site;
  index index.html;

  location = / {
    try_files /index.html =404;
  }

  location /gr/ {
    alias /var/www/site/gr/;
    index index.html;
    try_files $uri $uri/ =404;
  }

  # Serve other static files normally
  location / {
    try_files $uri $uri/ =404;
  }
}
